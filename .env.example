# CMDR Local Development Configuration
# Copy this file to .env and adjust values as needed

# ============================================================================
# Docker Compose Host Port Overrides (optional)
# ============================================================================
# Defaults preserve current behavior. Change only when host ports are occupied.
# CMDR_HOST_POSTGRES_PORT=5432
# CMDR_HOST_JAEGER_UI_PORT=16686
# CMDR_HOST_JAEGER_HTTP_PORT=14268
# CMDR_HOST_JAEGER_AGENT_UDP_PORT=6831
# CMDR_HOST_JAEGER_GRPC_PORT=14250
# CMDR_HOST_API_PORT=8080
# CMDR_HOST_OTLP_GRPC_PORT=4317
# CMDR_HOST_OTLP_HTTP_PORT=4318
# CMDR_HOST_FREEZETOOLS_PORT=9090

# ============================================================================
# Service Configuration
# ============================================================================
CMDR_API_PORT=8080
CMDR_LOG_LEVEL=debug

# ============================================================================
# OTLP Receiver Configuration
# ============================================================================
CMDR_OTLP_GRPC_ENDPOINT=0.0.0.0:4317
CMDR_OTLP_HTTP_ENDPOINT=0.0.0.0:4318

# ============================================================================
# Trace Fetcher (Optional - for historical traces)
# ============================================================================
# CMDR_JAEGER_URL=http://localhost:16686
# CMDR_TEMPO_URL=http://localhost:3200

# ============================================================================
# Agentgateway Client Configuration
# ============================================================================
# Replace with your actual agentgateway URL
CMDR_AGENTGATEWAY_URL=http://localhost:8080
CMDR_AGENTGATEWAY_TIMEOUT=60s
CMDR_AGENTGATEWAY_RETRY_ATTEMPTS=3

# ============================================================================
# Freeze-Tools MCP Server Configuration
# ============================================================================
CMDR_FREEZETOOLS_PORT=9090

# ============================================================================
# Database Configuration
# ============================================================================
# For local development with docker-compose
CMDR_POSTGRES_URL=postgres://cmdr:cmdr_dev_password@localhost:5432/cmdr?sslmode=disable
CMDR_POSTGRES_MAX_CONNS=50

# For running tests
# CMDR_POSTGRES_URL=postgres://cmdr:cmdr_dev_password@localhost:5432/cmdr_test?sslmode=disable

# ============================================================================
# Replay Engine Configuration
# ============================================================================
CMDR_WORKER_POOL_SIZE=10
CMDR_MAX_CONCURRENT_REPLAYS=5

# ============================================================================
# Evaluation Configuration
# ============================================================================
CMDR_LLM_JUDGE_MODEL=claude-3-5-sonnet-20241022
CMDR_EVAL_TIMEOUT=120s

# ============================================================================
# Authentication (Optional)
# ============================================================================
# Uncomment to enable JWT authentication
# CMDR_JWT_SECRET=your-secret-key-change-this-in-production
# CMDR_JWT_EXPIRY=24h
